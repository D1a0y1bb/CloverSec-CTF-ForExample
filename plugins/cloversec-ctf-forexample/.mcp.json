      "command": "python3",
      "args": [
        "./scripts/cloversec_ctf_search_mcp.py"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "cloversec-ctf-browser-search": {
      "cwd": ".",
      "command": "python3",
      "args": [
        "./scripts/cloversec_ctf_browser_search_mcp.py"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
